{
  "openapi": "3.0.3",
  "info": {
    "title": "IML Orchestrator — HTTP API (клиентский порт ui_http)",
    "description": "Оставшиеся маршруты оркестратора на порту `ui_http`: health, батч метаданных камер (с `file_path` к локальным артефактам при наличии), черновик эталона, кэш результата инспекции, CRUD FP зон через analisSurface с синхронизацией `client_ws`. Документация OpenAPI на этом порту не отдаётся — используйте этот файл из репозитория. Отдельный порт fan-out client stub (если включён) не описан здесь.",
    "version": "0.2.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8099",
      "description": "ui_http.host / ui_http.port"
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Проверка процесса"
    },
    {
      "name": "ui_cameras",
      "description": "Метаданные последних артефактов по камерам 0…4"
    },
    {
      "name": "reference_draft",
      "description": "Черновик эталона (пауза пайплайна)"
    },
    {
      "name": "inspection",
      "description": "Кэш JSON server.inspect_result"
    },
    {
      "name": "orchestrator_fp",
      "description": "FP зоны через analisSurface + синхронизация RAM оркестратора"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Liveness",
        "responses": {
          "200": {
            "description": "text/plain: ok",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "example": "ok\n" }
              }
            }
          }
        }
      }
    },
    "/api/cameras/latest.json": {
      "get": {
        "tags": ["ui_cameras"],
        "summary": "Пять слотов камер 0…4",
        "description": "Массив `cameras`: метаданные, `hasCurrent`/`hasHeatmap`, размеры; при наличии файлов — `currentJpeg.file_path` и `heatmapU8.file_path` (абсолютные пути на машине оркестратора).",
        "responses": {
          "200": {
            "description": "JSON",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    },
    "/api/reference-draft/status": {
      "get": {
        "tags": ["reference_draft"],
        "summary": "Статус черновика",
        "responses": {
          "200": { "description": "paused, frozen_slots, server_ts_ms" }
        }
      }
    },
    "/api/reference-draft/start": {
      "post": {
        "tags": ["reference_draft"],
        "summary": "Начать черновик",
        "responses": { "200": { "description": "{\"ok\":true}" } }
      }
    },
    "/api/reference-draft/cancel": {
      "post": {
        "tags": ["reference_draft"],
        "summary": "Отменить черновик",
        "responses": { "200": { "description": "{\"ok\":true}" } }
      }
    },
    "/api/reference-draft/confirm": {
      "post": {
        "tags": ["reference_draft"],
        "summary": "Подтвердить эталон",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "type": "object" } }
          }
        },
        "responses": { "200": { "description": "{\"ok\":true}" } }
      }
    },
    "/api/inspection/result": {
      "get": {
        "tags": ["inspection"],
        "summary": "Последний server.inspect_result",
        "parameters": [
          {
            "name": "camera_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "frame_id",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Конверт server.inspect_result",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          },
          "400": { "description": "Неверные параметры" },
          "404": { "description": "Нет кэша для камеры/кадра" },
          "503": { "description": "Кэш не настроен" }
        }
      }
    },
    "/api/orchestrator/fp-zones": {
      "get": {
        "tags": ["orchestrator_fp"],
        "summary": "Список FP зон (analisSurface)",
        "parameters": [
          {
            "name": "product_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Ответ analisSurface" } }
      },
      "post": {
        "tags": ["orchestrator_fp"],
        "summary": "Добавить зону + синхронизация оркестратора",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "type": "object" } }
          }
        },
        "responses": { "200": { "description": "Ответ analisSurface" } }
      }
    },
    "/api/orchestrator/fp-zones/{zoneId}": {
      "delete": {
        "tags": ["orchestrator_fp"],
        "summary": "Удалить зону + синхронизация",
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "product_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Ответ analisSurface" } }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
