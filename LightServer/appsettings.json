{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LightSettings": {
    "ComPort": "COM3",
    "SimulateHardware": false,
    "SimulateIfInitFailed": true,
    "TurnOffAllOnInit": true,
    "FlashMode": "Trigger",
    "DefaultBrightness": 100,
    "DefaultDurationMs": 180,
    "CameraPortMap": {
      "0": 1,
      "1": 2,
      "2": 3,
      "3": 4,
      "4": 1
    },
    "InspectionFlashPorts": [1, 2, 3, 4]
  },
  "AllowedHosts": "*"
}