{
  "version": 4,
  "configurations": [
    {
      "name": "macOS",
      "compilerPath": "/usr/bin/clang",
      "cStandard": "c17",
      "intelliSenseMode": "macos-clang-arm64",
      "includePath": [
        "${workspaceFolder}/**",
        "/opt/homebrew/opt/aravis/include/aravis-0.8",
        "/opt/homebrew/opt/glib/include",
        "/opt/homebrew/opt/glib/include/glib-2.0",
        "/opt/homebrew/opt/glib/lib/glib-2.0/include",
        "/opt/homebrew/opt/libmicrohttpd/include",
        "/opt/homebrew/opt/jpeg-turbo/include",
        "/opt/homebrew/opt/libusb/include/libusb-1.0"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "/opt/homebrew/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
